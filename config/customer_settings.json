{
  "timezone": "Asia/Shanghai",
  "whatsapp": {
    "use_current_logged_in_account": true,
    "global_scan_lock_enabled": true,

    "groups": [
      {
        "id": "group_test",
        "name": "test",
        "enabled": true,

        "scan": {
          "enabled": true,
          "interval_minutes": 20,
          "start_offset_seconds": 0,
          "skip_if_previous_scan_running": true
        },

        "reminder": {
          "enabled": true,
          "days_of_week": ["MON", "TUE", "WED", "THU", "FRI", "SAT", "SUN"],
          "times": ["12:00", "18:00"],
          "max_reminders_per_event_per_day": 2,
          "skip_completed_events": true
        },

        "related_site_ids": ["site_repulse_bay", "site_lpp"]
      },
      {
        "id": "group_maintenance_a",
        "name": "工程維修群A",
        "enabled": true,

        "scan": {
          "enabled": false,
          "interval_minutes": 30,
          "start_offset_seconds": 180,
          "skip_if_previous_scan_running": true
        },

        "reminder": {
          "enabled": true,
          "days_of_week": ["MON", "TUE", "WED", "THU", "FRI"],
          "times": ["12:15", "18:15"],
          "max_reminders_per_event_per_day": 2,
          "skip_completed_events": true
        },

        "related_site_ids": ["site_repulse_bay"]
      }
    ]
  },

  "sites": [
    {
      "id": "site_repulse_bay",
      "name": "淺水灣",
      "aliases": ["淺水灣", "浅水湾", "Repulse Bay"],
      "enabled": true
    },
    {
      "id": "site_lpp",
      "name": "LPP",
      "aliases": ["LPP", "LPP Free Access", "L212D", "L322", "L323B"],
      "enabled": true
    }
  ],

  "event_rules": {
    "completed_keywords": [
      "已完成",
      "完成",
      "搞掂",
      "done",
      "fixed",
      "solved",
      "resolved"
    ],
    "pending_keywords": [
      "需報價",
      "需要報價",
      "待報價",
      "需跟進",
      "未完成",
      "待處理",
      "冇畫面",
      "失靈",
      "故障",
      "壞",
      "入水"
    ]
  },

  "photo_record_rules": {
    "enabled": true,
    "require_photo_for_quotation": true,
    "require_photo_for_replacement": true,
    "require_pdf_report_for_atal_material": true,
    "required_photo_types": [
      "wide_shot",
      "close_up",
      "before_replacement",
      "during_replacement",
      "after_replacement",
      "delivery_photo"
    ]
  }
}
