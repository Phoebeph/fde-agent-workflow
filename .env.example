APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

DATA_ROOT=
DATABASE_PATH=./data/whatsapp_repair.db
ARCHIVE_ROOT=./archive
DOWNLOADS_ROOT=./downloads/yingdao
EXPORTS_ROOT=./exports
LOGS_ROOT=./logs
BACKUPS_ROOT=./backups

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Feishu is optional. Keep these empty for local-only deployment.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_UPLOAD_PARENT_TYPE=bitable_file
FEISHU_UPLOAD_PARENT_NODE=
FEISHU_MOCK_MODE=false

WHATSAPP_GROUP_NAME=
REMINDER_DAILY_LIMIT=1
AUTO_ANALYZE_ON_INGEST=true
AUTO_EXPORT_ON_INGEST=true
AUTO_PIPELINE_BACKGROUND=true
AUTO_SYNC_FEISHU_ON_INGEST=false
DISPATCH_MANAGER_SENDERS=Dicky Company,Rex Atl,Ono atl
FOLLOWUP_MANAGER_SENDERS=Henry atl
